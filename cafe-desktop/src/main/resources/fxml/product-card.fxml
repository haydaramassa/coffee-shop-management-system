<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import java.lang.String?>
<AnchorPane prefHeight="235.0" prefWidth="190.0"
            stylesheets="@../styles/mainform.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cafe.cafedesktop.ProductCardController">
    <children>
        <VBox spacing="10.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>
            <styleClass>
                <String fx:value="white-bg" />
                <String fx:value="radius" />
                <String fx:value="shadow" />
            </styleClass>

            <children>
                <AnchorPane prefHeight="120.0" prefWidth="170.0"
                            style="-fx-background-color: #f5f5f5; -fx-background-radius: 8;">
                    <children>
                        <ImageView fx:id="product_imageView"
                                   fitHeight="110.0"
                                   fitWidth="150.0"
                                   layoutX="10.0"
                                   layoutY="5.0"
                                   pickOnBounds="true"
                                   preserveRatio="true"
                                   AnchorPane.bottomAnchor="5.0"
                                   AnchorPane.leftAnchor="10.0"
                                   AnchorPane.rightAnchor="10.0"
                                   AnchorPane.topAnchor="5.0" />
                    </children>
                </AnchorPane>

                <Label fx:id="product_name"
                       maxWidth="1.7976931348623157E308"
                       text="Product Name"
                       wrapText="true">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label fx:id="product_type"
                       text="Category"
                       style="-fx-text-fill: #666; -fx-font-size: 12px;" />

                <HBox alignment="CENTER_LEFT" spacing="6.0">
                    <children>
                        <Label fx:id="product_price"
                               text="0.0 $"
                               style="-fx-text-fill: #0f6789; -fx-font-size: 16px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="product_stock"
                               text="Stock: 0"
                               style="-fx-text-fill: #666; -fx-font-size: 12px;" />
                    </children>
                </HBox>

                <Region VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Spinner fx:id="product_spinner"
                                 prefHeight="32.0"
                                 prefWidth="78.0" />
                        <Button fx:id="product_addBtn"
                                mnemonicParsing="false"
                                onAction="#addBtn"
                                prefHeight="32.0"
                                prefWidth="82.0"
                                styleClass="btn"
                                text="Add" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>